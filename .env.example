# 定时任务表达式。
# 格式：分钟 小时 日 月 星期。
# 默认表示 Asia/Shanghai 时区每天 15:00 执行。
BILI_UP_TASK_CRON=0 15 * * *

# 每日任务开关。
BILI_UP_WATCH_VIDEO=true
BILI_UP_SHARE_VIDEO=true
BILI_UP_NUMBER_OF_COINS=5
BILI_UP_PROTECTED_COINS=0
BILI_UP_SAVE_COINS_WHEN_LV6=false
BILI_UP_SELECT_LIKE=true

# 优先支持的 UP 主 UID 列表，多个用英文逗号分隔，例如：123456,987654
BILI_UP_SUPPORT_UP_IDS=

# 请求间隔和超时时间，单位秒。
BILI_UP_REQUEST_INTERVAL_SECONDS=3
BILI_UP_TIMEOUT_SECONDS=30

# 账号 Cookie 保存位置。
# Docker 中程序工作目录是 /app，因此这里对应 /app/config/accounts.json。
BILI_UP_ACCOUNTS_FILE=config/accounts.json

# 日志会按天写入 logs/bili-up-YYYY-MM-DD.log。
# 保留最近 N 天日志；设置为 0 或负数表示不自动清理历史日志。
BILI_UP_LOG_RETENTION_DAYS=90

# 请求身份配置。
# 如果 B 站接口返回风控错误，可以改成你浏览器里的真实 UA。
BILI_UP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/149.0.0.0 Safari/537.36
